# Server Environment Config
PORT=3000

# Database
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# AI API (DeepSeek)
AI_API_KEY=your_api_key_here
AI_API_BASE=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# Volcengine Jimeng AI
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Qiniu OSS
QINIU_ACCESS_KEY=your_qiniu_access_key
QINIU_SECRET_KEY=your_qiniu_secret_key
QINIU_BUCKET=your_bucket_name
QINIU_DOMAIN=http://tgam7g9pi.hn-bkt.clouddn.com
QINIU_REGION=Zone_z2

# WeChat Mini Program
WX_MINI_APPID=your_appid
WX_MINI_SECRET=your_secret

# WeChat Pay (微信支付)
WX_MCH_ID=your_mch_id                    # 商户号
WX_API_V3_KEY=your_api_v3_key            # APIv3密钥
WX_SERIAL_NO=your_serial_no              # 证书序列号
WX_PRIVATE_KEY=your_private_key_or_path  # 商户私钥内容或文件路径
WX_NOTIFY_URL=https://your-domain.com/api/v1/point/recharge/notify  # 支付回调地址

# Points
POINTS_PER_GENERATION=10
NEW_USER_BONUS=50
